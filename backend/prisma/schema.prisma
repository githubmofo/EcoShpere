// ─── Master Data Models ─────────────────────────────────────────────

model Department {
  id                 String              @id @default(uuid())
  name               String
  code               String              @unique
  headUserId         String?
  parentDepartmentId String?
  employeeCount      Int                 @default(0)
  status             String              @default("ACTIVE")

  // Relations
  headUser           User?               @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentDepartment   Department?         @relation("SubDepartments", fields: [parentDepartmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subDepartments     Department[]        @relation("SubDepartments")
  users              User[]              @relation("DepartmentUsers")
  carbonTransactions CarbonTransaction[]
  environmentalGoals EnvironmentalGoal[]
  audits             Audit[]
  departmentScores   DepartmentScore[]
}

model Category {
  id          String         @id @default(uuid())
  name        String
  type        String
  status      String         @default("ACTIVE")
  
  csrActivities CsrActivity[]
  challenges    Challenge[]
}

model EmissionFactor {
  id          String   @id @default(uuid())
  name        String
  factorValue Float
  unit        String
  status      String   @default("ACTIVE")
}

model EnvironmentalGoal {
  id               String     @id @default(uuid())
  departmentId     String
  targetEmissions  Float
  startDate        DateTime
  endDate          DateTime
  status           String     @default("ACTIVE")

  department       Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EsgPolicy {
  id               String                  @id @default(uuid())
  title            String
  description      String                  @db.Text
  effectiveDate    DateTime
  status           String                  @default("ACTIVE")

  acknowledgements PolicyAcknowledgement[]
}

model Badge {
  id              String            @id @default(uuid())
  name            String
  description     String
  unlockRuleType  String            // e.g., "XP_THRESHOLD", "CHALLENGE_COUNT"
  unlockThreshold Int
  iconUrl         String
  
  assignments     BadgeAssignment[]
}

model Reward {
  id              String             @id @default(uuid())
  name            String
  description     String
  pointsRequired  Int
  stock           Int
  status          String             @default("ACTIVE")

  redemptions     RewardRedemption[]
}

model User {
  id                  String                   @id @default(uuid())
  name                String
  email               String                   @unique
  passwordHash        String
  role                String                     @default("EMPLOYEE")
  departmentId        String?

  department          Department?              @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  headedDepartments   Department[]             @relation("DepartmentHead")
  
  participations      EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  policyAcknowledgements PolicyAcknowledgement[]
  auditsConducted     Audit[]                  @relation("AuditAuditor")
  complianceIssuesOwned ComplianceIssue[]      @relation("IssueOwner")
  xpBalance           EmployeeXpBalance?
  badges              BadgeAssignment[]
  rewardRedemptions   RewardRedemption[]
  notifications       Notification[]
}

// ─── Transactional Data Models ──────────────────────────────────────

model CarbonTransaction {
  id              String     @id @default(uuid())
  departmentId    String
  sourceType      String
  quantity        Float
  emissionsValue  Float
  operationDate   DateTime
  autoCalculated  Boolean    @default(false)

  department      Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model CsrActivity {
  id              String                  @id @default(uuid())
  title           String
  categoryId      String
  description     String                  @db.Text
  startDate       DateTime
  endDate         DateTime
  status          String               @default("PLANNED")

  category        Category                @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  participations  EmployeeParticipation[]
}

model EmployeeParticipation {
  id              String         @id @default(uuid())
  employeeId      String
  csrActivityId   String
  proofPath       String?
  approvalStatus  String @default("PENDING")
  pointsEarned    Int            @default(0)
  completionDate  DateTime?

  employee        User           @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  csrActivity     CsrActivity    @relation(fields: [csrActivityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Challenge {
  id               String                   @id @default(uuid())
  title            String
  categoryId       String
  description      String                   @db.Text
  xpAward          Int
  difficulty       String                   // e.g., "Easy", "Medium", "Hard"
  evidenceRequired Boolean                  @default(true)
  deadline         DateTime
  status           String                   @default("ACTIVE")

  category         Category                 @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  participations   ChallengeParticipation[]
}

model ChallengeParticipation {
  id              String         @id @default(uuid())
  challengeId     String
  employeeId      String
  progressPercent Int            @default(0)
  proofPath       String?
  approvalStatus  String @default("PENDING")
  xpAwarded       Int            @default(0)

  challenge       Challenge      @relation(fields: [challengeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee        User           @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PolicyAcknowledgement {
  id              String     @id @default(uuid())
  policyId        String
  employeeId      String
  acknowledgedAt  DateTime   @default(now())

  policy          EsgPolicy  @relation(fields: [policyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee        User       @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Audit {
  id              String            @id @default(uuid())
  departmentId    String
  title           String
  description     String            @db.Text
  auditDate       DateTime
  auditorId       String
  status          String       @default("SCHEDULED")

  department      Department        @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditor         User              @relation("AuditAuditor", fields: [auditorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  complianceIssues ComplianceIssue[]
}

model ComplianceIssue {
  id              String      @id @default(uuid())
  auditId         String
  severity        String
  description     String      @db.Text
  ownerId         String
  dueDate         DateTime
  status          String @default("OPEN")
  flaggedOverdue  Boolean     @default(false)

  audit           Audit       @relation(fields: [auditId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  owner           User        @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model DepartmentScore {
  id                String     @id @default(uuid())
  departmentId      String
  environmentalScore Float
  socialScore       Float
  governanceScore   Float
  totalScore        Float
  computedAt        DateTime   @default(now())

  department        Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EmployeeXpBalance {
  id              String @id @default(uuid())
  employeeId      String @unique
  xpTotal         Int    @default(0)
  pointsTotal     Int    @default(0)

  employee        User   @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model BadgeAssignment {
  id              String   @id @default(uuid())
  badgeId         String
  employeeId      String
  awardedAt       DateTime @default(now())
  source          String?

  badge           Badge    @relation(fields: [badgeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee        User     @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model RewardRedemption {
  id              String         @id @default(uuid())
  rewardId        String
  employeeId      String
  pointsSpent     Int
  redeemedAt      DateTime       @default(now())
  status          String @default("APPROVED")

  reward          Reward         @relation(fields: [rewardId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee        User           @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Notification {
  id                String    @id @default(uuid())
  userId            String
  type              String
  title             String
  body              String    @db.Text
  relatedEntityType String?
  relatedEntityId   String?
  readAt            DateTime?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Configuration Models ───────────────────────────────────────────

model EsgConfiguration {
  id                      String  @id @default(uuid())
  envWeight               Float
  socialWeight            Float
  governanceWeight        Float
  autoEmissionEnabled     Boolean @default(true)
  evidenceRequiredEnabled Boolean @default(true)
  badgeAutoAwardEnabled   Boolean @default(true)
}

model NotificationSettings {
  id                          String  @id @default(uuid())
  emailEnabled                Boolean @default(true)
  inAppEnabled                Boolean @default(true)
  notifyOnComplianceIssue     Boolean @default(true)
  notifyOnComplianceOverdue   Boolean @default(true)
  notifyOnCsrApproval         Boolean @default(true)
  notifyOnChallengeApproval   Boolean @default(true)
  notifyOnPolicyReminder      Boolean @default(true)
  notifyOnBadgeUnlock         Boolean @default(true)
}
